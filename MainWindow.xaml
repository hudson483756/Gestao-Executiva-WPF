<Window x:Class="Projeto1_Excel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Sistema Gestão Corporativa" Height="600" Width="1000">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Coluna do Menu Lateral -->
            <ColumnDefinition Width="Auto"/>
            <!-- Coluna do Conteúdo Principal -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Menu Lateral -->
        <StackPanel Grid.Column="0" Background="#1B365D" Width="200">
            <TextBlock Text="CORP SYSTEM" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,20,0,20"/>

            <Button Content="📦 Cadastro" 
                    Command="{Binding NavegarParaCadastroCommand}" 
                    Foreground="White" Margin="5,10" 
                    />

            <Button Content="💰 Financeiro" 
                    Command="{Binding NavegarParaFinanceiroCommand}" 
                    Foreground="White" Margin="5,10" 
                    />

            <Button Content="📊 Relatórios" 
                    Command="{Binding NavegarParaRelatoriosCommand}" 
                    Foreground="White" Margin="5,10" 
                    />
        </StackPanel>

        <!-- Conteúdo Principal Dinâmico -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentView}" Margin="20"/>
    </Grid>
</Window>
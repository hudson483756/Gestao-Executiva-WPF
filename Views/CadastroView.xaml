<UserControl x:Class="Projeto1_Excel.Views.CadastroView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="White">

    <Grid Margin="16">
        <TabControl materialDesign:ColorZoneAssist.Mode="SecondaryMid">
            <!-- ABA DE CLIENTES -->
            <TabItem Header="👥 Clientes">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Inputs Corrigidos para MaterialDesign v4.9 -->
                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,16">
                        <TextBox materialDesign:HintAssist.Hint="Razão Social / Nome" 
                                 Width="250" Margin="0,0,10,0" 
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>

                        <TextBox materialDesign:HintAssist.Hint="CPF / CNPJ" 
                                 Width="150" Margin="0,0,10,0" 
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>

                        <Button Content="Salvar" Style="{StaticResource MaterialDesignRaisedButton}"/>
                    </StackPanel>

                    <!-- Tabela de Clientes -->
                    <DataGrid Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True"/>
                </Grid>
            </TabItem>

            <!-- ABA DE PRODUTOS -->
            <TabItem Header="📦 Produtos">
                <Grid Margin="0,16,0,0">
                    <!-- Estrutura para Produtos -->
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
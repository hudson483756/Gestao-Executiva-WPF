<UserControl x:Class="Projeto1_Excel.Views.RelatoriosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="White">

    <Grid Margin="16">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <materialDesign:PackIcon Kind="FileExcel" Width="80" Height="80" Foreground="#1B365D" HorizontalAlignment="Center" Margin="0,0,0,16"/>

            <TextBlock Text="Central de Relatórios Executivos" Style="{StaticResource MaterialDesignHeadline4TextBlock}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="Gere o fechamento completo consolidado diretamente para o Excel formatado." Style="{StaticResource MaterialDesignBody1TextBlock}" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,24"/>

            <Button Content="📊 Exportar para Excel (.xlsx)" 
                    Command="{Binding ExportarParaExcelCommand}"
                    Width="250" Height="45" FontSize="16" Background="#1B365D" BorderBrush="#1B365D" Style="{StaticResource MaterialDesignRaisedDarkButton}"/>
        </StackPanel>
    </Grid>
</UserControl>